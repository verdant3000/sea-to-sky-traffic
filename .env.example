# Copy this file to .env and edit before running.
# All values have defaults — you only need to set what differs from the defaults.

# --- Station identity ---
STATION_ID=1
STATION_NAME=test-mac

# --- Central API ---
API_ENDPOINT=https://sea-to-sky-traffic-production.up.railway.app
API_KEY=                        # must match API_KEY on the Railway service
SYNC_INTERVAL=60

# --- Camera ---
# Mac webcam: 0 (or 1 if external camera)
# Pi HQ Camera via v4l2: 0  (same)
CAMERA_SOURCE=0

# --- Detection ---
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4

# --- Tripwire ---
# Fraction of frame height from top where vehicles are counted (0.0–1.0)
# 0.5 = middle of frame. Adjust after you see the video feed.
TRIPWIRE_Y=0.5

# Direction labels — which way the road runs relative to camera orientation
# centroid moving DOWN in frame = DIRECTION_DOWN
DIRECTION_UP=northbound
DIRECTION_DOWN=southbound

# --- SQLite buffer ---
DB_PATH=detections.db

# --- Speed estimation (rough calibration) ---
CAMERA_HEIGHT_M=4.0
CAMERA_ANGLE_DEG=30.0
FRAME_RATE=10

# --- BME280 environmental sensors (Pi only) ---
# I2C addresses: SDO pulled high = 0x77, SDO to GND = 0x76
# Default: inside case = 0x77, outside ambient = 0x76
ENV_INSIDE_I2C_ADDR=0x77
ENV_OUTSIDE_I2C_ADDR=0x76
ENV_READ_INTERVAL=60       # seconds between sensor reads
ENV_SYNC_INTERVAL=300      # seconds between API syncs
INSIDE_TEMP_MAX_C=55.0     # alert threshold for case temperature
INSIDE_HUMIDITY_MAX=80.0   # alert threshold for case humidity (%RH)
