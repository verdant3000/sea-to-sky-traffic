# Copy to .env for local development.
# Railway injects DATABASE_URL and PORT automatically — don't set them there.

# PostgreSQL connection string
# Local:   postgres://postgres:password@localhost:5432/seatosky
# Railway: set automatically from the Postgres plugin
DATABASE_URL=postgres://postgres:password@localhost:5432/seatosky

# Server port (Railway sets this automatically)
PORT=3000

# Shared secret sent by Pi stations in X-Api-Key header.
# Set the same value in each Pi's .env as API_KEY.
# Leave blank to disable auth (local dev only).
API_KEY=

# Environment (development | production)
NODE_ENV=development
